VITE_API_BASE_URL=http://localhost:8000/api/v1
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://qa_rag:qa_rag@localhost:5432/qa_rag
ALEMBIC_DATABASE_URL=postgresql+asyncpg://qa_rag:qa_rag@localhost:5432/qa_rag
JWT_SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=documents
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION must match EMBEDDING_MODEL output dimension.
EMBEDDING_DIMENSION=1536
STORAGE_ROOT=backend/storage
MAX_UPLOAD_BYTES=52428800
USE_ASYNC_INGESTION=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_IGNORE_RESULT=true
CELERY_WORKER_CONCURRENCY=1
CELERY_MAX_TASKS_PER_CHILD=50
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_SEMANTIC_TOP_K=20
RETRIEVAL_FINAL_TOP_K=8
CONTEXT_MAX_CHARS=12000
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_MIN_SIMILARITY=0.85
SEMANTIC_CACHE_TIMEOUT_MS=75
SEMANTIC_CACHE_INDEX_NAME=idx:semcache
SEMANTIC_CACHE_KEY_PREFIX=semcache:
